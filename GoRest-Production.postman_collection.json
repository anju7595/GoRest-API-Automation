{
  "info": {
    "_postman_id": "b78a9cd4-b78e-4401-9fcc-b336f2c3c2bc",
    "name": "GoRest-Production",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "53885887",
    "_collection_link": "https://go.postman.co/collection/53885887-b78a9cd4-b78e-4401-9fcc-b336f2c3c2bc?source=collection_link"
  },
  "item": [
    {
      "name": "Create user",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// 1. Validate the Status Code\r",
              "pm.test(\"Status code is 201 Created\", function () {\r",
              "    pm.response.to.have.status(201);\r",
              "});\r",
              "\r",
              "// 2. Parse the response\r",
              "var jsonData = pm.response.json();\r",
              "\r",
              "// 3. Verify specific data points\r",
              "pm.test(\"Verify User Name and Status\", function () {\r",
              "    pm.expect(jsonData.name).to.eql(\"Anju Professional QA\");\r",
              "    pm.expect(jsonData.status).to.eql(\"active\");\r",
              "});\r",
              "\r",
              "// 4. SMART STEP: Save the User ID for future requests\r",
              "// This allows the next 'GET' or 'PUT' to know exactly which user to target\r",
              "if (jsonData.id) {\r",
              "    pm.environment.set(\"user_id\", jsonData.id);\r",
              "    console.log(\"Current User ID saved: \" + jsonData.id);\r",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n    \"name\": \"Anju Professional QA\",\r\n    \"gender\": \"female\",\r\n    \"email\": \"anju.test.{{$randomInt}}@testmail.com\",\r\n    \"status\": \"active\"\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{base_url}}/users",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "users"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Get User ID",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// 1. Level 1 Check: Basic Connectivity\r",
              "pm.test(\"Status code is 200 OK\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "// 2. Parse the Response\r",
              "var jsonData = pm.response.json();\r",
              "\r",
              "// 3. Level 2 Check: Data Integrity (The \"Senior\" way)\r",
              "// We check if the ID in the response matches the ID we saved earlier\r",
              "pm.test(\"Response matches the requested User ID\", function () {\r",
              "    var expectedId = pm.environment.get(\"user_id\");\r",
              "    pm.expect(jsonData.id.toString()).to.eql(expectedId.toString());\r",
              "});\r",
              "\r",
              "// 4. Level 3 Check: Content Validation\r",
              "pm.test(\"User has correct Profile details\", function () {\r",
              "    pm.expect(jsonData.name).to.be.a('string');\r",
              "    pm.expect(jsonData).to.have.property('email');\r",
              "    pm.expect(jsonData.status).to.be.oneOf([\"active\", \"inactive\"]);\r",
              "});\r",
              "\r",
              "// 5. Practical Debugging (Visible in Postman Console)\r",
              "console.log(\"Successfully fetched data for User: \" + jsonData.name + \" (ID: \" + jsonData.id + \")\");"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/users/{{user_id}}",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "users",
            "{{user_id}}"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Update User info",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Validate update reflected\", function () {\r",
              "    var jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.status).to.eql(\"inactive\");\r",
              "    pm.expect(jsonData.name).to.eql(\"Anju QA Updated\");\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "PUT",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n    \"name\": \"Anju QA Updated\",\r\n    \"status\": \"inactive\"\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{base_url}}/users/{{user_id}}",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "users",
            "{{user_id}}"
          ]
        }
      },
      "response": []
    },
    {
      "name": "DELETE - Remove User",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"User deleted successfully\", function () {\r",
              "    // GoRest returns 204 (No Content) for successful deletes\r",
              "    pm.response.to.have.status(204);\r",
              "});\r",
              "\r",
              "// Cleanup the environment variable\r",
              "pm.environment.unset(\"user_id\");"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{base_url}}/users/{{user_id}}",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "users",
            "{{user_id}}"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Verify Deletion",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// We EXPECT a 404 because the user was deleted in the previous step\r",
              "pm.test(\"Status code is 404 Not Found\", function () {\r",
              "    pm.response.to.have.status(404);\r",
              "});\r",
              "\r",
              "pm.test(\"Error message confirms resource is gone\", function () {\r",
              "    var jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.message).to.eql(\"Resource not found\");\r",
              "});\r",
              "\r",
              "console.log(\"Negative Test Passed: User is confirmed deleted from database.\");"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/users/{{user_id}}",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "users",
            "{{user_id}}"
          ]
        }
      },
      "response": []
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{api_token}}",
        "type": "string"
      }
    ]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "packages": {},
        "requests": {},
        "exec": [
          "// Add browser-like headers to bypass bot detection\r",
          "\r",
          "pm.request.headers.upsert({\r",
          "    key: \"User-Agent\",\r",
          "    value: \"Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 Chrome/120 Safari/537.36\"\r",
          "});\r",
          "\r",
          "pm.request.headers.upsert({\r",
          "    key: \"Accept\",\r",
          "    value: \"application/json\"\r",
          "});\r",
          "\r",
          "pm.request.headers.upsert({\r",
          "    key: \"Connection\",\r",
          "    value: \"keep-alive\"\r",
          "});"
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "packages": {},
        "requests": {},
        "exec": [
          ""
        ]
      }
    }
  ],
  "variable": [
    {
      "key": "api_token",
      "value": ""
    }
  ]
}